<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/youtube_white">

    <TextView
        android:id="@+id/txtDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/youtube_red"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/txtYoutubeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YouTube URL:"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/txtDashboardTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="28dp"
        android:layout_marginStart="32dp" />

    <EditText
        android:id="@+id/editYoutubeUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Paste YouTube video link here"
        android:inputType="textUri"
        android:padding="14dp"
        android:background="@drawable/edit_text_bg"
        android:textColor="@color/black"
        android:textColorHint="@color/youtube_dark_gray"
        app:layout_constraintTop_toBottomOf="@id/txtYoutubeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <Button
        android:id="@+id/btnPlayVideo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="PLAY"
        android:textStyle="bold"
        android:textColor="@color/youtube_white"
        android:backgroundTint="@color/youtube_red"
        app:layout_constraintTop_toBottomOf="@id/editYoutubeUrl"
        app:layout_constraintStart_toStartOf="@id/editYoutubeUrl"
        app:layout_constraintEnd_toEndOf="@id/editYoutubeUrl"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btnAddToPlaylist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="ADD TO PLAYLIST"
        android:textStyle="bold"
        android:textColor="@color/youtube_red"
        android:backgroundTint="@color/youtube_light_gray"
        app:layout_constraintTop_toBottomOf="@id/btnPlayVideo"
        app:layout_constraintStart_toStartOf="@id/btnPlayVideo"
        app:layout_constraintEnd_toEndOf="@id/btnPlayVideo"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnOpenLibrary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="MY PLAYLIST"
        android:textStyle="bold"
        android:textColor="@color/youtube_red"
        android:backgroundTint="@color/youtube_light_gray"
        app:layout_constraintTop_toBottomOf="@id/btnAddToPlaylist"
        app:layout_constraintStart_toStartOf="@id/btnAddToPlaylist"
        app:layout_constraintEnd_toEndOf="@id/btnAddToPlaylist"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnLogoutDashboard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="LOGOUT"
        android:textStyle="bold"
        android:textColor="@color/youtube_white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toBottomOf="@id/btnOpenLibrary"
        app:layout_constraintStart_toStartOf="@id/btnOpenLibrary"
        app:layout_constraintEnd_toEndOf="@id/btnOpenLibrary"
        android:layout_marginTop="18dp" />

</androidx.constraintlayout.widget.ConstraintLayout>